{
  "name": "react-adaptive-text",
  "version": "1.0.1",
  "description": "Picks a legible text color from a background (WCAG 2.1 + optional APCA). AdaptiveText, context theme, zero native code.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "source": "src/index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typescript": "npm run typecheck",
    "dev:example": "npm install --prefix example && npm run dev --prefix example"
  },
  "keywords": [
    "react",
    "web",
    "accessibility",
    "a11y",
    "wcag",
    "wcag-2.1",
    "contrast",
    "contrast-ratio",
    "apca",
    "luminance",
    "adaptive-text",
    "adaptive-color",
    "text-color",
    "color",
    "palette",
    "typescript"
  ],
  "author": {
    "name": "Muhammad Uzair Aslam",
    "url": "https://github.com/iuzairaslam/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iuzairaslam/react-native-adaptive-text.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "homepage": "https://github.com/iuzairaslam/react-native-adaptive-text#readme",
  "bugs": {
    "url": "https://github.com/iuzairaslam/react-native-adaptive-text/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
