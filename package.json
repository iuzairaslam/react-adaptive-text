{
  "name": "@iuzairaslam/react-adaptive-text",
  "version": "1.0.4",
  "description": "Readable text on any background—WCAG & APCA aware React components and color helpers (TypeScript).",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "README.md",
    "LICENSE",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:all": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typescript": "npm run typecheck",
    "dev:example": "npm install --prefix example && npm run dev --prefix example",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org --access public",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com"
  },
  "keywords": [
    "react",
    "web",
    "accessibility",
    "a11y",
    "wcag",
    "wcag-2.1",
    "contrast",
    "contrast-ratio",
    "apca",
    "luminance",
    "adaptive-text",
    "adaptive-color",
    "text-color",
    "color",
    "palette",
    "typescript",
    "react-dom",
    "vite",
    "nextjs"
  ],
  "author": {
    "name": "Muhammad Uzair Aslam",
    "url": "https://github.com/iuzairaslam/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iuzairaslam/react-adaptive-text.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "homepage": "https://github.com/iuzairaslam/react-adaptive-text#readme",
  "bugs": {
    "url": "https://github.com/iuzairaslam/react-adaptive-text/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
